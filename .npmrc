# xterm 6.0.0 is intentionally used together with addon-canvas / addon-webgl
# beta versions whose declared peerDependency on @xterm/xterm doesn't quite
# match (addon-canvas still says ^5.0.0; addon-webgl latest beta wants
# ^6.1.0-beta.197). The combination works at runtime — see TerminalView.tsx
# — but `npm ci` in CI fails strict peer-dep resolution.
#
# Accept the legacy peer behavior so install succeeds. Revisit when the
# addons publish releases with peer declarations that match xterm@6.x.
legacy-peer-deps=true
